# Tonel deployment environment.
# Copy this file to `.env.deploy` (gitignored) and fill in real values.
#
#   cp deploy/.env.deploy.example deploy/.env.deploy

# ─── Production server ──────────────────────────────────────────────────────

# SSH target — must accept root login from your local key (passwordless).
# Production is 酷番云广州 (42.240.163.172, SSH on port 26806) since v5.0.0.
# A second box at Aliyun (8.163.21.207, port 22) serves the `/new` fallback
# path. To run a deploy script against Aliyun, override inline:
#   TONEL_SSH_HOST=root@8.163.21.207 TONEL_SSH_PORT=22 deploy/health.sh
TONEL_SSH_HOST=root@42.240.163.172

# SSH port — defaults to 22 if unset. v5.0+ production uses 26806 (non-standard).
TONEL_SSH_PORT=26806

# Production install root. The new layout (v1.0.3+) is `/opt/tonel/`.
# The legacy layout `/opt/tonel-server/` is preserved as `/opt/_archive/`.
TONEL_DEPLOY_DIR=/opt/tonel

# Runtime data (recordings, runtime configs). Outside of TONEL_DEPLOY_DIR so
# it survives clean re-deploys.
TONEL_RUNTIME_DIR=/var/lib/tonel

# PM2 stdout/stderr per process.
TONEL_LOG_DIR=/var/log/tonel

# Where backup snapshots of TONEL_DEPLOY_DIR are stored (timestamped).
TONEL_ARCHIVE_DIR=/opt/_archive

# Cloudflare Tunnel ID — used to substitute into ops/cloudflared/config.yml.template.
# Find via `cloudflared tunnel list` or the existing /root/.cloudflared/config.yml.
# v5.0.0+ tunnels:
#   tonel-koufan = 6fb5a319-7aaa-4f77-9e12-214eb4bfb1d8 (酷番云, primary, this file)
#   tonel-tunnel = 339745d7-cb58-4e1d-acf4-e6b7198a2b8c (Aliyun, fallback)
TONEL_CF_TUNNEL_ID=

# ─── Cloudflare Pages (web frontend) ─────────────────────────────────────────

# API token. Generate at https://dash.cloudflare.com/profile/api-tokens.
# Required permissions (wrangler 4.x is stricter than earlier versions —
# missing any of these surfaces as `Authentication error [code: 10000]`
# on a `/memberships` API call, sometimes only after a previous deploy
# in the same session has succeeded):
#   - Account → Cloudflare Pages → Edit
#   - User → User Details → Read
#   - User → Memberships → Read
CLOUDFLARE_API_TOKEN=

# (Optional) explicitly set the account ID if your token is multi-account.
# CLOUDFLARE_ACCOUNT_ID=

# Cloudflare Pages project name (matches what `wrangler pages deploy` uses).
TONEL_CF_PAGES_PROJECT=tonel-web

# ─── Health check ────────────────────────────────────────────────────────────

# Seconds to wait per health probe before declaring it failed.
TONEL_HEALTH_TIMEOUT=10
