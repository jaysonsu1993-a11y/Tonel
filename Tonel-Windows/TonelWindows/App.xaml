<Application x:Class="TonelWindows.App.AppEntry"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="BgBrush"        Color="#121214"/>
            <SolidColorBrush x:Key="PanelBrush"     Color="#1A1A1F"/>
            <SolidColorBrush x:Key="StripBrush"     Color="#1A1A1F"/>
            <SolidColorBrush x:Key="DividerBrush"   Color="#22FFFFFF"/>
            <SolidColorBrush x:Key="TextPrimary"    Color="#E6E6E6"/>
            <SolidColorBrush x:Key="TextSecondary"  Color="#8C8C8C"/>
            <SolidColorBrush x:Key="TextTertiary"   Color="#5E5E5E"/>
            <SolidColorBrush x:Key="AccentGreen"    Color="#22C55E"/>
            <SolidColorBrush x:Key="AccentBlue"     Color="#1F478C"/>
            <SolidColorBrush x:Key="AccentRed"      Color="#8C1A1A"/>
            <SolidColorBrush x:Key="MeterYellow"    Color="#EAB308"/>
            <SolidColorBrush x:Key="MeterRed"       Color="#EF4444"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
