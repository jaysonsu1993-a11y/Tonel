<Window x:Class="TonelWindows.Views.SwitchRoomSheet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="切换房间" Width="380" Height="240"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A1F" Foreground="#E6E6E6"
        WindowStyle="None" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="切换房间" FontSize="22" FontWeight="Bold"/>
        <TextBlock Grid.Row="1" TextWrapping="Wrap" FontSize="11" Foreground="#999"
                   Margin="0,8,0,0"
                   Text="输入想去的房间号。3–32 位字母 / 数字。 房间不存在时会自动创建。"/>
        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <TextBlock Text="房间号" FontSize="11" Foreground="#999"/>
            <TextBox x:Name="RoomIdBox" Background="#212126" Foreground="White"
                     BorderBrush="#3D3D3D" Padding="6" FontSize="13" Margin="0,4,0,0"
                     CharacterCasing="Upper"/>
        </StackPanel>
        <Grid Grid.Row="4" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="取消" HorizontalAlignment="Left" Width="80"
                    Height="32" Background="#2E2E38" Foreground="White" BorderThickness="0"
                    Click="OnCancel"/>
            <Button Grid.Column="1" Content="确定" Width="80" Height="32"
                    Background="#1F478C" Foreground="White" BorderThickness="0"
                    Click="OnOk" IsDefault="True"/>
        </Grid>
    </Grid>
</Window>
