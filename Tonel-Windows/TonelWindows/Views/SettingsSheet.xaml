<Window x:Class="TonelWindows.Views.SettingsSheet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置" Width="540" Height="640"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A1F" Foreground="#E6E6E6"
        WindowStyle="None" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="设置" FontSize="22" FontWeight="Bold"/>

        <ScrollViewer Grid.Row="1" Margin="0,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Server + transport -->
                <TextBlock Text="服务器与传输模式" FontSize="13" FontWeight="Bold"
                           Foreground="#D9D9D9" Margin="0,0,0,8"/>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="服务器" Width="80" FontSize="12" Foreground="#B2B2B2"/>
                    <ComboBox x:Name="ServerCombo" Width="350" SelectionChanged="OnServerOrTransportChanged"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="传输模式" Width="80" FontSize="12" Foreground="#B2B2B2"/>
                    <ComboBox x:Name="TransportCombo" Width="350" SelectionChanged="OnServerOrTransportChanged"/>
                </StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#999" Margin="0,4">
                    UDP 直连最低延迟， WS 走 TCP 兼容受限网络， P2P 在 LAN / 锥形 NAT 下端到端最少跳。
                    切换会自动重连同一个房间。
                </TextBlock>

                <Rectangle Height="1" Fill="#2C2C32" Margin="0,16"/>

                <!-- Audio devices -->
                <TextBlock Text="音频设备" FontSize="13" FontWeight="Bold" Foreground="#D9D9D9"/>
                <StackPanel Orientation="Horizontal" Margin="0,8">
                    <TextBlock Text="输入" Width="80" FontSize="12" Foreground="#B2B2B2"/>
                    <ComboBox x:Name="InputCombo" Width="350" SelectionChanged="OnInputChanged"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="输出" Width="80" FontSize="12" Foreground="#B2B2B2"/>
                    <ComboBox x:Name="OutputCombo" Width="350" SelectionChanged="OnOutputChanged"/>
                </StackPanel>
                <TextBlock x:Name="ErrorText" Foreground="#EF4444" FontSize="11" Margin="0,4"/>

                <TextBlock Text="WASAPI Exclusive 模式" FontSize="13" FontWeight="Bold"
                           Foreground="#D9D9D9" Margin="0,16,0,4"/>
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#999">
                    Tonel 强制使用 WASAPI Exclusive 模式（独占设备）以获得最低延迟。
                    Tonel 运行时其他 app 无法用同一个声卡发声 — 这是预期行为。
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#999" Margin="0,4">
                    要求设备支持 48000 Hz Exclusive 格式。 打开失败时请到系统声音设置
                    （右键托盘音量图标 → 声音 → 设备属性 → 高级）确认默认采样率为 48000 Hz。
                </TextBlock>

                <TextBlock x:Name="ActualText" FontSize="11" Foreground="#999" Margin="0,8"/>

                <Rectangle Height="1" Fill="#2C2C32" Margin="0,16"/>

                <!-- Identity -->
                <TextBlock Text="身份" FontSize="13" FontWeight="Bold" Foreground="#D9D9D9"/>
                <StackPanel Margin="0,8">
                    <TextBlock x:Name="UserIdText" FontSize="11" FontFamily="Consolas" Foreground="#B2B2B2"/>
                    <TextBlock x:Name="MyRoomText" FontSize="11" FontFamily="Consolas" Foreground="#B2B2B2"
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button Content="重置身份" Width="120" HorizontalAlignment="Left"
                        Background="#3B0F0F" Foreground="#FFD9D9" BorderBrush="#7A1A1A"
                        BorderThickness="1" Padding="8,4" Click="OnResetIdentity"/>
                <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#999" Margin="0,6">
                    生成全新的 userId / 房间号， 之前的房间会失去访问权（除非记得房间号让朋友再分享）。
                </TextBlock>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="好" HorizontalAlignment="Right" Width="80" Height="32"
                Background="#1F478C" Foreground="White" BorderThickness="0"
                IsDefault="True" Click="OnOk"/>
    </Grid>
</Window>
