<UserControl x:Class="TonelWindows.Views.RoomView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:TonelWindows.Views"
             Background="{StaticResource BgBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1A1A1F" Padding="20,14"
                BorderBrush="#0FFFFFFF" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <StackPanel>
                        <TextBlock Text="房间号" FontSize="10" Foreground="#808080"/>
                        <TextBlock x:Name="RoomIdText" FontSize="18" FontWeight="Bold"
                                   FontFamily="Consolas" Foreground="White"
                                   MouseDown="OnRoomIdTriple"/>
                    </StackPanel>
                    <Button x:Name="CopyBtn" Content="复制" Margin="12,0,0,0"
                            Padding="10,4" FontSize="12"
                            Background="#212121" Foreground="#D9D9D9"
                            BorderThickness="0" Click="OnCopy"/>
                </StackPanel>

                <Button Grid.Column="2" Content="⚙ 设置" FontSize="13" Margin="8,0"
                        Background="Transparent" Foreground="#B2B2B2" BorderThickness="0"
                        Click="OnSettings"/>

                <Button Grid.Column="3" x:Name="MicBtn" FontSize="12" FontWeight="Bold"
                        FontFamily="Consolas" Padding="12,6" Margin="8,0"
                        Foreground="White" BorderThickness="0"
                        Click="OnToggleMic"/>

                <Border Grid.Column="4" Background="#1A1A1A" CornerRadius="4"
                        Padding="10,4" Margin="8,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="延迟" FontSize="10" Foreground="#808080"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="E2eText" FontSize="12" FontWeight="Bold"
                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                        <TextBlock Text="·" Foreground="#666" Margin="6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="RTT" FontSize="10" Foreground="#808080"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock x:Name="RttText" FontSize="12" FontWeight="Bold"
                                   FontFamily="Consolas" VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Button Grid.Column="5" Content="切换房间" Padding="12,6" Margin="8,0,0,0"
                        FontSize="12" Background="#262626" Foreground="#D9D9D9"
                        BorderThickness="0" Click="OnSwitchRoom"/>
                <Button Grid.Column="6" x:Name="ReturnHomeBtn" Content="返回我的房间"
                        Padding="12,6" Margin="8,0,0,0" Visibility="Collapsed"
                        FontSize="12" Background="#1A4D80" Foreground="#D9D9D9"
                        BorderThickness="0" Click="OnReturnHome"/>
            </Grid>
        </Border>

        <!-- Banner -->
        <Border Grid.Row="1" x:Name="BannerHost" Visibility="Collapsed" Padding="24,8">
            <TextBlock x:Name="BannerText" Foreground="White" FontSize="12"/>
        </Border>

        <!-- Debug bar -->
        <Border Grid.Row="2" Background="Black" Padding="24,4">
            <DockPanel>
                <Button x:Name="TestToneBtn" Content="TEST TONE" DockPanel.Dock="Right"
                        FontSize="10" Background="Transparent" Foreground="#22C55E"
                        BorderThickness="0" Click="OnTestTone"/>
                <TextBlock x:Name="DebugLine" FontFamily="Consolas" FontSize="11"
                           Foreground="#22C55E" TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Body -->
        <ScrollViewer Grid.Row="3" Padding="20" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- MIXER section -->
                <DockPanel Margin="0,0,0,8">
                    <Border DockPanel.Dock="Left" Background="#212121" CornerRadius="3"
                            Padding="8,3">
                        <TextBlock Text="MIXER" FontSize="11" FontWeight="Bold"
                                   FontFamily="Consolas" Foreground="#8C8C8C"/>
                    </Border>
                    <TextBlock x:Name="MixerCountText" FontSize="10" FontFamily="Consolas"
                               Foreground="#808080" VerticalAlignment="Center" Margin="8,0"/>
                </DockPanel>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="MixerStrips" Orientation="Horizontal"/>
                </ScrollViewer>

                <!-- INPUT TRACKS section -->
                <DockPanel Margin="0,16,0,8">
                    <Border DockPanel.Dock="Left" Background="#212121" CornerRadius="3"
                            Padding="8,3">
                        <TextBlock Text="INPUT TRACKS" FontSize="11" FontWeight="Bold"
                                   FontFamily="Consolas" Foreground="#8C8C8C"/>
                    </Border>
                    <TextBlock x:Name="InputCountText" FontSize="10" FontFamily="Consolas"
                               Foreground="#808080" VerticalAlignment="Center" Margin="8,0"/>
                </DockPanel>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="InputStrips" Orientation="Horizontal"/>
                </ScrollViewer>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
