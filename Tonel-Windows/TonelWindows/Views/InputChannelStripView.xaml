<UserControl x:Class="TonelWindows.Views.InputChannelStripView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:v="clr-namespace:TonelWindows.Views">
    <StackPanel Width="120">
        <Grid Margin="0,0,0,4" Height="22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <ComboBox x:Name="DeviceMenu" Grid.Column="0" FontSize="11"
                      Background="#212121" Foreground="{StaticResource TextPrimary}"
                      BorderBrush="#4D4D4D" BorderThickness="1"
                      SelectionChanged="OnDeviceChanged"/>
            <Button x:Name="RemoveBtn" Grid.Column="1" Content="×"
                    Width="18" Height="20" Margin="4,0,0,0"
                    Background="#3B0F0F" Foreground="#FFD9D9"
                    BorderBrush="#7A1A1A" BorderThickness="1"
                    FontWeight="Bold" FontSize="12"
                    Click="OnRemoveClick"/>
        </Grid>
        <v:ChannelStripView x:Name="Strip"/>
    </StackPanel>
</UserControl>
