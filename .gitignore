# =============================================================================
# Tonel .gitignore
#
# Repo layout (post-flatten, 2026-05-01):
#   Repo root = working tree root. Standard layout. Local-only content lives
#   OUTSIDE this directory at ~/project-s/Tonel-local/.
#
# Anything that does *not* match this file is intended to be tracked.
# Keep this file the single source of truth — there is no nested .gitignore.
# =============================================================================

# Build artifacts (CMake + Unix)
build/
build_/
build_*/
build-*/
cmake-build-*/
**/build/
**/build_*/
_build/
**/_build/

# clangd LSP local index (machine-specific, gets rebuilt on demand)
.cache/
**/.cache/

# Binaries
bin/
server/bin/
# Cross-compiled Go proxy binary (deploy/server.sh wt-proxy step
# produces this at the source dir; the 10MB ELF was leaking into
# release commits via `git add -A` until v4.3.3 added it here.)
server/wt-mixer-proxy/wt-mixer-proxy

# Xcode generated
build_xcode/
build-xcode/
*.xcodeproj/
*.xcworkspace/

# Desktop build dirs (specific names)
build-desktop/
build_xcode_legacy/

# JUCE (external)
/JUCE/

# OS files
.DS_Store
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.code-workspace
.claude/

# Logs
*.log

# macOS apps
*.app/

# Runtime config (generated/overridden per deployment)
config.json

# Web / Node
**/node_modules/
**/dist/

# CF Workers / Wrangler local cache
**/.wrangler/

# Environment files
.env

# Deploy secrets (SSH host, CF token, tunnel id)
deploy/.env.deploy

# v6.5.2: distribution artifacts built locally, uploaded to R2 — not committed
deploy/dist/

# Playwright MCP runtime artifacts (screenshot output goes to repo root by default)
.playwright-mcp/
tonel-home-with-downloads.png
