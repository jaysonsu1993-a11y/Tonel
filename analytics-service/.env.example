# Tonel analytics service environment.
# Copy to `.env` and fill in real values.
#   cp .env.example .env

# Port the analytics HTTP server listens on.
PORT=9007

# JWT secret for issuing/verifying admin login tokens.
# MUST match user-service if you want shared SSO; otherwise pick a fresh
# 32+ character random string. Change before deploy to production.
JWT_SECRET=change-me-to-a-long-random-string

# Static admin password (PBKDF2 of plaintext, see scripts/hash.js).
# Quick demo: leave plain "admin123" — server hashes on boot.
# Production: pre-hash and store the hash here.
ADMIN_USER=admin
ADMIN_PASSWORD=admin123

# CORS allowlist (comma-separated). The tracker snippet calls /api/track
# from the public site, so include every origin that runs the snippet.
# Use "*" for development only.
CORS_ORIGINS=https://tonel.io,https://www.tonel.io,http://localhost:5173,http://localhost:9007

# Optional: trust the X-Forwarded-For header set by Cloudflare / nginx.
# Required for correct visitor IP capture behind a proxy.
TRUST_PROXY=1

# Optional: how many days of raw visit rows to keep. Older rows are
# rolled into the daily aggregate and dropped. 0 = keep forever.
RETENTION_DAYS=90
