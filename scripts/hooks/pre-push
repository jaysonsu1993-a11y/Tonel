#!/bin/bash
#
# pre-push: enforce the "main accepts release commits only" rule locally.
#
# Per memory `feedback_versioning` (STANDARDS_VERSIONING strict release flow):
#   main 禁止裸 commit; every push must be `release: vX.Y.Z` after the full
#   bump+CHANGES+tag+push pipeline. This hook is the fence — without it the
#   policy is just a sentence in a doc.
#
# Bypass intentionally with `git push --no-verify` if you really need to.
# Branch protection on GitHub would enforce this server-side too, but
# requires GitHub Pro on private repos.
#
# Install: `scripts/install-hooks.sh` (sets core.hooksPath).

set -e

while read -r local_ref local_sha remote_ref _; do
    [[ "$remote_ref" == "refs/heads/main" ]] || continue

    if [[ "$local_sha" == "0000000000000000000000000000000000000000" ]]; then
        # Branch deletion. Refuse — this is main.
        echo "❌  pre-push: refusing to delete main."
        exit 1
    fi

    # Inspect every new commit being pushed (HEAD..remote-tip).
    # If we can't resolve the remote tip, fall back to inspecting just HEAD.
    range="$local_sha"
    if git rev-parse --verify "@{u}" >/dev/null 2>&1; then
        range="@{u}..$local_sha"
    fi

    bad=0
    while read -r sha subject; do
        [[ -z "$sha" ]] && continue
        if [[ ! "$subject" =~ ^release:\ v[0-9]+\.[0-9]+\.[0-9]+ ]]; then
            echo "❌  pre-push: main accepts only 'release: vX.Y.Z' commits."
            echo "    blocked: $sha  $subject"
            bad=1
        fi
    done < <(git log --format='%H %s' "$range" 2>/dev/null || git log --format='%H %s' -1 "$local_sha")

    if (( bad )); then
        echo
        echo "Run from a feature branch instead, or finish the release pipeline:"
        echo "  - bump version markers"
        echo "  - update CHANGELOG.md"
        echo "  - commit as 'release: vX.Y.Z'"
        echo "  - tag vX.Y.Z"
        echo
        echo "(emergency override: git push --no-verify)"
        exit 1
    fi
done

exit 0
