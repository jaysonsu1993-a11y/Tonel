// S1SignalingClient.cpp — POSIX TCP implementation of the S1 signaling protocol
//
// Wire format: newline-delimited JSON over a persistent TCP connection.
// Message types mirror those in S1-Desktop/src/network/SignalingClient.h.

#include "S1SignalingClient.h"

#include <chrono>
#include <sys/socket.h>
#include <sys/select.h>
#include <netinet/in.h>
#include <netinet/tcp.h>
#include <arpa/inet.h>
#include <netdb.h>
#include <unistd.h>
#include <cerrno>
#include <cstring>
#include <sstream>
#include <cassert>
#include <cstdio>

// ── Construction / destruction ────────────────────────────────────────────────

S1SignalingClient::S1SignalingClient()  = default;
S1SignalingClient::~S1SignalingClient() { disconnect(); }

// ── connect ───────────────────────────────────────────────────────────────────

bool S1SignalingClient::connect(const std::string& host, int port)
{
    disconnect();   // close any existing connection

    struct addrinfo hints{}, *res = nullptr;
    hints.ai_family   = AF_UNSPEC;
    hints.ai_socktype = SOCK_STREAM;

    char portStr[16];
    std::snprintf(portStr, sizeof(portStr), "%d", port);

    if (getaddrinfo(host.c_str(), portStr, &hints, &res) != 0 || !res) {
        if (callback_) callback_->onSignalingError("DNS resolution failed: " + host);
        return false;
    }

    fd_ = ::socket(res->ai_family, res->ai_socktype, res->ai_protocol);
    if (fd_ < 0) {
        freeaddrinfo(res);
        if (callback_) callback_->onSignalingError("socket() failed");
        return false;
    }

    // TCP_NODELAY for low-latency signaling
    int flag = 1;
    ::setsockopt(fd_, IPPROTO_TCP, TCP_NODELAY, &flag, sizeof(flag));

    if (::connect(fd_, res->ai_addr, res->ai_addrlen) != 0) {
        ::close(fd_);  fd_ = -1;
        freeaddrinfo(res);
        if (callback_) callback_->onSignalingError("connect() failed: " + std::string(strerror(errno)));
        return false;
    }
    freeaddrinfo(res);

    connected_.store(true, std::memory_order_release);
    running_.store(true, std::memory_order_release);

    recvThread_ = std::thread([this]{ receiveLoop(); });

    if (callback_) callback_->onSignalingConnected();
    return true;
}

// ── disconnect ────────────────────────────────────────────────────────────────

void S1SignalingClient::disconnect()
{
    running_.store(false, std::memory_order_release);
    connected_.store(false, std::memory_order_release);
    if (fd_ >= 0) {
        ::shutdown(fd_, SHUT_RDWR);
        ::close(fd_);
        fd_ = -1;
    }
    if (recvThread_.joinable()) recvThread_.join();
}

// ── Room actions ──────────────────────────────────────────────────────────────

void S1SignalingClient::createRoom(const std::string& roomId, const std::string& userId,
                                    const std::string& password)
{
    std::string msg = "{\"type\":\"CREATE_ROOM\","
                    + jsonString("room_id", roomId) + ","
                    + jsonString("user_id", userId);
    if (!password.empty()) {
        msg += "," + jsonString("password", password);
    }
    msg += "}\n";
    send(msg);
}

void S1SignalingClient::joinRoom(const std::string& roomId, const std::string& userId,
                                  const std::string& localIp, int localPort,
                                  const std::string& password)
{
    std::string msg = "{\"type\":\"JOIN_ROOM\","
                    + jsonString("room_id", roomId) + ","
                    + jsonString("user_id", userId) + ","
                    + jsonString("ip", localIp.empty() ? "0.0.0.0" : localIp) + ","
                    + jsonInt("port", localPort);
    if (!password.empty()) {
        msg += "," + jsonString("password", password);
    }
    msg += "}\n";
    send(msg);
}

void S1SignalingClient::leaveRoom(const std::string& roomId, const std::string& userId)
{
    std::string msg = "{\"type\":\"LEAVE_ROOM\","
                    + jsonString("room_id", roomId) + ","
                    + jsonString("user_id", userId) + "}\n";
    send(msg);
}

// ── receive loop (runs on background thread) ──────────────────────────────────

void S1SignalingClient::receiveLoop()
{
    char buf[4096];

    while (running_.load(std::memory_order_acquire) && fd_ >= 0) {
        // Use select with 200 ms timeout so we can check running_ regularly
        fd_set rfds;
        FD_ZERO(&rfds);
        FD_SET(fd_, &rfds);
        struct timeval tv{ 0, 200 * 1000 };   // 200 ms

        int r = ::select(fd_ + 1, &rfds, nullptr, nullptr, &tv);
        if (r < 0) break;           // error / socket closed
        if (r == 0) continue;       // timeout — loop and re-check running_

        ssize_t n = ::recv(fd_, buf, sizeof(buf) - 1, 0);
        if (n <= 0) break;          // connection closed or error

        buf[n] = '\0';
        recvBuf_.append(buf, (size_t)n);

        // Process complete lines
        std::string::size_type pos;
        while ((pos = recvBuf_.find('\n')) != std::string::npos) {
            std::string line = recvBuf_.substr(0, pos);
            recvBuf_.erase(0, pos + 1);
            if (!line.empty()) processLine(line);
        }
    }

    bool wasConnected = connected_.exchange(false, std::memory_order_acq_rel);
    if (wasConnected && callback_) callback_->onSignalingDisconnected();
}

// ── message parsing ───────────────────────────────────────────────────────────

void S1SignalingClient::processLine(const std::string& json)
{
    std::string type = extractStr(json, "type");

    if      (type == "CREATE_ROOM_ACK") {
        if (callback_) callback_->onRoomCreated(extractStr(json, "room_id"));
    }
    else if (type == "JOIN_ROOM_ACK") {
        if (callback_) callback_->onRoomJoined(extractStr(json, "room_id"));
    }
    else if (type == "PEER_LIST") {
        if (callback_) callback_->onPeerList(extractStr(json, "room_id"),
                                             extractPeers(json));
    }
    else if (type == "PEER_JOINED") {
        S1PeerInfo p;
        p.user_id = extractStr(json, "user_id");
        p.ip      = extractStr(json, "ip");
        p.port    = extractInt(json, "port");
        if (callback_) callback_->onPeerJoined(p);
    }
    else if (type == "PEER_LEFT") {
        if (callback_) callback_->onPeerLeft(extractStr(json, "user_id"));
    }
    else if (type == "HEARTBEAT_ACK") {
        // ignore
    }
    else if (type == "ERROR") {
        if (callback_) callback_->onSignalingError(extractStr(json, "message"));
    }
    // else: unknown type, silently ignore
}

// ── send helper ───────────────────────────────────────────────────────────────

void S1SignalingClient::send(const std::string& msg)
{
    std::lock_guard<std::mutex> lk(sendMutex_);
    if (fd_ < 0 || !connected_.load()) return;

    const char* p   = msg.c_str();
    ssize_t     rem = (ssize_t)msg.size();
    while (rem > 0) {
        ssize_t n = ::send(fd_, p, (size_t)rem, MSG_NOSIGNAL);
        if (n <= 0) {
            // Send failed — close connection and notify
            bool wasConnected = connected_.exchange(false, std::memory_order_acq_rel);
            if (wasConnected && callback_)
                callback_->onSignalingError("send() failed: " + std::string(strerror(errno)));
            return;
        }
        p   += n;
        rem -= n;
    }
}

// ── Minimal JSON helpers ──────────────────────────────────────────────────────

std::string S1SignalingClient::jsonString(const std::string& k, const std::string& v) const {
    return "\"" + k + "\":\"" + v + "\"";
}

std::string S1SignalingClient::jsonInt(const std::string& k, int v) const {
    return "\"" + k + "\":" + std::to_string(v);
}

/// Extract first string value for a given key from flat JSON.
/// Handles only simple single-level key:"value" patterns.
std::string S1SignalingClient::extractStr(const std::string& json,
                                           const std::string& key) const
{
    std::string needle = "\"" + key + "\":\"";
    auto pos = json.find(needle);
    if (pos == std::string::npos) return {};
    pos += needle.size();
    auto end = json.find('"', pos);
    if (end == std::string::npos) return {};
    return json.substr(pos, end - pos);
}

int S1SignalingClient::extractInt(const std::string& json, const std::string& key) const
{
    std::string needle = "\"" + key + "\":";
    auto pos = json.find(needle);
    if (pos == std::string::npos) return 0;
    pos += needle.size();
    // skip whitespace
    while (pos < json.size() && json[pos] == ' ') ++pos;
    return std::stoi(json.substr(pos));
}

/// Extract "peers":[{...},{...}] array from a peer_list message.
std::vector<S1PeerInfo> S1SignalingClient::extractPeers(const std::string& json) const
{
    std::vector<S1PeerInfo> peers;

    auto arrStart = json.find("\"peers\":[");
    if (arrStart == std::string::npos) return peers;
    arrStart += std::string("\"peers\":[").size();

    auto arrEnd = json.find(']', arrStart);
    if (arrEnd == std::string::npos) return peers;

    std::string arr = json.substr(arrStart, arrEnd - arrStart);

    // Walk through each {...} object in the array
    std::string::size_type i = 0;
    while (i < arr.size()) {
        auto objStart = arr.find('{', i);
        if (objStart == std::string::npos) break;
        auto objEnd = arr.find('}', objStart);
        if (objEnd == std::string::npos) break;

        std::string obj = arr.substr(objStart, objEnd - objStart + 1);
        S1PeerInfo p;
        p.user_id = extractStr(obj, "user_id");
        p.ip      = extractStr(obj, "ip");
        p.port    = extractInt(obj, "port");
        if (!p.user_id.empty()) peers.push_back(p);

        i = objEnd + 1;
    }
    return peers;
}
