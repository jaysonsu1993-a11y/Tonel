# Tonel deployment environment.
# Copy this file to `.env.deploy` (gitignored) and fill in real values.
#
#   cp Git/deploy/.env.deploy.example Git/deploy/.env.deploy

# ─── Production server ──────────────────────────────────────────────────────

# SSH target — must accept root login from your local key (passwordless).
TONEL_SSH_HOST=root@8.163.21.207

# Production install root. The new layout (v1.0.3+) is `/opt/tonel/`.
# The legacy layout `/opt/tonel-server/` is preserved as `/opt/_archive/`.
TONEL_DEPLOY_DIR=/opt/tonel

# Runtime data (recordings, runtime configs). Outside of TONEL_DEPLOY_DIR so
# it survives clean re-deploys.
TONEL_RUNTIME_DIR=/var/lib/tonel

# PM2 stdout/stderr per process.
TONEL_LOG_DIR=/var/log/tonel

# Where backup snapshots of TONEL_DEPLOY_DIR are stored (timestamped).
TONEL_ARCHIVE_DIR=/opt/_archive

# Cloudflare Tunnel ID — used to substitute into ops/cloudflared/config.yml.template.
# Find via `cloudflared tunnel list` or the existing /root/.cloudflared/config.yml.
TONEL_CF_TUNNEL_ID=

# ─── Cloudflare Pages (web frontend) ─────────────────────────────────────────

# API token with `Cloudflare Pages — Edit` permission. Generate at:
#   https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# (Optional) explicitly set the account ID if your token is multi-account.
# CLOUDFLARE_ACCOUNT_ID=

# Cloudflare Pages project name (matches what `wrangler pages deploy` uses).
TONEL_CF_PAGES_PROJECT=tonel-web

# ─── Health check ────────────────────────────────────────────────────────────

# Seconds to wait per health probe before declaring it failed.
TONEL_HEALTH_TIMEOUT=10
