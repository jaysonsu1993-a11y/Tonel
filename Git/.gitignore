# Build artifacts (CMake + Unix)
build/
build_/
build_*/
cmake-build-*/
**/build/
**/build_*/
_build/
**/_build/

# clangd LSP local index (machine-specific, gets rebuilt on demand)
.cache/
**/.cache/

# Binaries
bin/
server/bin/

# Xcode generated
build_xcode/
build-xcode/
*.xcodeproj/
*.xcworkspace/

# Desktop build dirs (specific names)
build-desktop/
build_xcode_legacy/

# JUCE (external)
/JUCE/

# OS files
.DS_Store
*.swp
*.swo
*~

# IDE
.vscode/
.idea/
*.code-workspace

# Logs
*.log

# macOS apps
*.app/

# Runtime config (generated/overridden per deployment)
config.json

# Web
web/dist/
web/node_modules/

# Environment files
.env

# Deploy secrets (SSH host, CF token, tunnel id)
deploy/.env.deploy
