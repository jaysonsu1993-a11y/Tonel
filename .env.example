# S1 Server Deployment Environment
# Copy this file to .env and fill in actual values.
# DO NOT commit .env to git.

# Domain configuration
SIGNALING_DOMAIN=signal.tonel.io
WEB_DOMAIN=tonel.io

# Server IP (for deploy script)
SERVER_IP=<your-server-ip>
SSH_USER=<your-ssh-user>
SSH_PORT=22
SSH_PASSWORD=

# Ports
SIGNALING_PORT=9001
MIXER_TCP_PORT=9002
MIXER_UDP_PORT=9003
WS_PROXY_PORT=9004
WEBRTC_PROXY_RECV_PORT=9007
WEBRTC_DTLS_PORT_BEGIN=10000
WEBRTC_DTLS_PORT_END=10100
